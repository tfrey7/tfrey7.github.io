---
import Base from '../layouts/Base.astro';
import { contact, skills, experience, education } from '../data/profile';

const contactBits = [
  contact.location,
  contact.email,
  contact.phone,
].filter(Boolean);
---

<Base title={`${contact.name} — Resume`}>
  <main class="resume">
    <!-- Header -->
    <header>
      <h1 class="resume-name">{contact.name.toUpperCase()}</h1>
      <p class="resume-contact">
        {contactBits.join(' • ')}
        {' • '}
        <a href={contact.github}>github.com/tfrey7</a>
      </p>
    </header>

    <!-- Skills -->
    <section class="resume-section skills-stage" aria-labelledby="skills-heading">
      <h2 id="skills-heading" class="resume-section-title">Technical Skills</h2>

      <ul class="resume-bullets">
        {
          skills.map((group) => (
            <li>
              <span class="skill-item font-semibold text-slate-900 dark:text-slate-100">
                {group.label}:
              </span>{' '}
              {group.items.flatMap((item, i) => [
                <span class="skill-item">{item}</span>,
                i < group.items.length - 1 ? <span>, </span> : null,
              ])}
            </li>
          ))
        }
      </ul>

      <div class="skills-curtain skills-curtain-left" aria-hidden="true"></div>
      <div class="skills-curtain skills-curtain-right" aria-hidden="true"></div>
    </section>

    <!-- Experience -->
    <section class="resume-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="resume-section-title">Professional Experience</h2>

      {
        experience.map((role) => (
          <article class="mt-4 first:mt-3">
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <h3 class="resume-role-header">
                {role.company} <span class="font-normal text-slate-500">|</span>{' '}
                <span class="font-normal">{role.location}</span>
              </h3>
            </div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <p class="resume-role-title">{role.title}</p>
              <p class="resume-meta">{role.start} – {role.end}</p>
            </div>
            {role.bullets.length > 0 && (
              <ul class="resume-bullets">
                {role.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }

      <article class="mt-4">
        <h3 class="resume-role-header">
          {education.school} <span class="font-normal text-slate-500">|</span>{' '}
          <span class="font-normal">{education.location}</span>
        </h3>
        <p class="resume-role-title">{education.degree}</p>
      </article>
    </section>
  </main>
</Base>

<script>
  type Direction = 'left' | 'right';

  const stage = document.querySelector<HTMLElement>('.skills-stage');
  const SETTLE_MS = 1200;
  const CURTAIN_CLOSE_MS = 420;
  const CURTAIN_HOLD_MS = 800;
  let fixTimer: number | null = null;
  let cascading = false;

  function fall(el: HTMLElement, direction: Direction, delay: number) {
    const fallsOff = Math.random() < 0.22;

    if (fallsOff) {
      // Spins off the section: heavy rotation + translate past the bottom edge.
      const sideBias = direction === 'right' ? 1 : -1;
      const spinSign = Math.random() < 0.6 ? sideBias : -sideBias;
      const spinMagnitude = 220 + Math.random() * 540;
      const fallX = sideBias * Math.random() * 180;
      const fallY = 320 + Math.random() * 360;
      const duration = 0.75 + Math.random() * 0.4;

      el.style.setProperty('--fall-angle', `${spinSign * spinMagnitude}deg`);
      el.style.setProperty('--fall-x', `${fallX}px`);
      el.style.setProperty('--fall-y', `${fallY}px`);
      el.style.setProperty('--fall-duration', `${duration}s`);
      el.classList.add('is-falling-off');
    } else {
      // Tip-over: wider angle range + occasional sideways slide + varied speed.
      const magnitude = 22 + Math.random() * 78;
      const signed = direction === 'right' ? magnitude : -magnitude;
      const slide = Math.random() < 0.4 ? (Math.random() - 0.5) * 16 : 0;
      const duration = 0.32 + Math.random() * 0.4;

      el.style.setProperty('--fall-angle', `${signed}deg`);
      el.style.setProperty('--fall-origin', direction === 'right' ? '0% 100%' : '100% 100%');
      el.style.setProperty('--fall-duration', `${duration}s`);
      if (slide !== 0) el.style.setProperty('--fall-x', `${slide}px`);
    }

    window.setTimeout(() => {
      if (el.classList.contains('is-fallen')) return;
      el.classList.add('is-fallen');
      scheduleFix();
    }, delay);
  }

  function startCascade(clickX: number, clickY: number) {
    if (!stage || cascading || stage.classList.contains('is-fixing')) return;
    cascading = true;

    const items = Array.from(stage.querySelectorAll<HTMLElement>('.skill-item'));

    // Rank items by distance from click — nearest will fall first.
    const ranked = items
      .map((el) => {
        const r = el.getBoundingClientRect();
        const cx = (r.left + r.right) / 2;
        const cy = (r.top + r.bottom) / 2;
        const dx = cx - clickX;
        const dy = cy - clickY;
        return {
          el,
          dist: Math.sqrt(dx * dx + dy * dy),
          direction: (dx >= 0 ? 'right' : 'left') as Direction,
        };
      })
      .sort((a, b) => a.dist - b.dist);

    // Spreading-panic pacing: 1 falls, beat, another, then 2, 3, 5, then domino.
    const waveSizes = [1, 1, 2, 3, 5];
    const waveDelays = [0, 320, 540, 700, 830];
    const FINAL_BASE = 950;
    const FINAL_STAGGER = 45;

    let cursor = 0;
    waveSizes.forEach((size, w) => {
      for (let j = 0; j < size && cursor < ranked.length; j++, cursor++) {
        const { el, direction } = ranked[cursor];
        fall(el, direction, waveDelays[w] + Math.random() * 50);
      }
    });

    let extra = 0;
    while (cursor < ranked.length) {
      const { el, direction } = ranked[cursor];
      fall(el, direction, FINAL_BASE + extra * FINAL_STAGGER + Math.random() * 35);
      cursor++;
      extra++;
    }
  }

  function scheduleFix() {
    if (fixTimer !== null) window.clearTimeout(fixTimer);
    fixTimer = window.setTimeout(runFix, SETTLE_MS);
  }

  function runFix() {
    fixTimer = null;
    if (!stage) return;
    const fallen = stage.querySelectorAll<HTMLElement>('.skill-item.is-fallen');
    if (fallen.length === 0) {
      cascading = false;
      return;
    }

    stage.classList.add('is-fixing');

    window.setTimeout(() => spawnSparks(stage, 16), CURTAIN_CLOSE_MS - 110);
    window.setTimeout(() => spawnPuffs(stage, 22), CURTAIN_CLOSE_MS - 80);

    window.setTimeout(() => {
      fallen.forEach((el) => {
        el.style.transition = 'none';
        el.classList.remove('is-fallen', 'is-falling-off');
        el.style.removeProperty('--fall-angle');
        el.style.removeProperty('--fall-origin');
        el.style.removeProperty('--fall-x');
        el.style.removeProperty('--fall-y');
        el.style.removeProperty('--fall-duration');
        void el.offsetHeight;
        el.style.transition = '';
      });
    }, CURTAIN_CLOSE_MS + 80);

    window.setTimeout(() => {
      stage.classList.remove('is-fixing');
      cascading = false;
    }, CURTAIN_CLOSE_MS + CURTAIN_HOLD_MS);
  }

  function spawnSparks(stageEl: HTMLElement, count: number) {
    // Sparks erupt at the seam impact in a single tight burst, then arc + fall.
    for (let i = 0; i < count; i++) {
      window.setTimeout(() => {
        const side: -1 | 1 = Math.random() < 0.5 ? -1 : 1;
        const left = 50 + side * Math.random() * 1.5;
        const top = 35 + Math.random() * 30;

        const spark = document.createElement('div');
        spark.className = 'skills-spark';
        spark.style.left = `${left}%`;
        spark.style.top = `${top}%`;

        // Outward velocity is mostly horizontal with a touch of upward arc.
        const speed = 50 + Math.random() * 90;
        const x = side * speed;
        const apexY = -(15 + Math.random() * 35);
        const fallY = 40 + Math.random() * 70;
        const size = 2 + Math.random() * 3;
        const duration = 500 + Math.random() * 250;

        spark.style.setProperty('--spark-x', `${x}px`);
        spark.style.setProperty('--spark-apex-y', `${apexY}px`);
        spark.style.setProperty('--spark-fall-y', `${fallY}px`);
        spark.style.setProperty('--spark-size', `${size}px`);
        spark.style.setProperty('--spark-duration', `${duration}ms`);

        stageEl.appendChild(spark);
        window.setTimeout(() => spark.remove(), duration + 50);
      }, Math.random() * 60);
    }
  }

  function spawnPuffs(stageEl: HTMLElement, count: number) {
    // Front-loaded eruption: most puffs in the first ~180ms, the rest trail off.
    const burstCount = Math.ceil(count * 0.65);
    for (let i = 0; i < count; i++) {
      const inBurst = i < burstCount;
      const delay = inBurst
        ? Math.random() * 180
        : 180 + (i - burstCount) * 70 + Math.random() * 50;

      window.setTimeout(() => {
        const isBack = i % 2 === 0;
        // Bias position toward the seam center; back puffs spread a touch wider.
        const sideRoll = Math.random();
        const side: -1 | 1 = sideRoll < 0.5 ? -1 : 1;
        const horizontalSpread = isBack ? 10 : 7;
        const left = 50 + side * (1 + Math.random() * horizontalSpread);
        const top = 18 + Math.random() * 64;

        const puff = document.createElement('div');
        puff.className = isBack ? 'skills-puff skills-puff--back' : 'skills-puff';
        puff.style.left = `${left}%`;
        puff.style.top = `${top}%`;

        const size = isBack
          ? 56 + Math.random() * 60
          : 30 + Math.random() * 40;
        // Drift outward from seam (away from center) and upward.
        const driftX = side * (20 + Math.random() * 70);
        const driftY = -(40 + Math.random() * 60);
        const rotate = side * (10 + Math.random() * 50);
        const scaleEnd = isBack ? 2.2 + Math.random() * 0.6 : 1.6 + Math.random() * 0.5;

        puff.style.setProperty('--puff-size', `${size}px`);
        puff.style.setProperty('--puff-drift-x', `${driftX}px`);
        puff.style.setProperty('--puff-drift-y', `${driftY}px`);
        puff.style.setProperty('--puff-rotate', `${rotate}deg`);
        puff.style.setProperty('--puff-scale-end', `${scaleEnd}`);

        stageEl.appendChild(puff);
        window.setTimeout(() => puff.remove(), isBack ? 1500 : 1150);
      }, delay);
    }
  }

  let autoTriggerArmed = true;

  stage?.addEventListener('mouseenter', (e) => {
    if (!autoTriggerArmed) return;
    autoTriggerArmed = false;
    startCascade(e.clientX, e.clientY);
  });

  stage?.addEventListener('click', (e) => {
    autoTriggerArmed = false;
    startCascade(e.clientX, e.clientY);
  });
</script>
