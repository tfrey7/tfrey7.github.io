---
import Base from '../layouts/Base.astro';
import { contact, skills, experience, education } from '../data/profile';
---

<Base title={`${contact.name} — Resume`}>
  <main class="resume">
    <!-- Header -->
    <header>
      <h1 class="resume-name">
        <span class="resume-name-inner">
          {contact.name.toUpperCase()}
          <span class="name-avatar" aria-hidden="true"></span>
        </span>
      </h1>
      <p class="resume-contact">
        {contact.location}
        {' • '}
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        {contact.phone ? <>{' • '}{contact.phone}</> : null}
        {' • '}
        <a href={contact.github}>github.com/tfrey7</a>
      </p>
    </header>

    <!-- Skills -->
    <section class="resume-section skills-stage" aria-labelledby="skills-heading">
      <h2 id="skills-heading" class="resume-section-title">Technical Skills</h2>

      <ul class="resume-bullets">
        {
          skills.map((group) => (
            <li>
              <span class="skill-item font-semibold text-slate-900 dark:text-slate-100">
                {group.label}:
              </span>{' '}
              {group.items.flatMap((item, i) => [
                <span class="skill-item">{item}</span>,
                i < group.items.length - 1 ? <span class="skill-sep">, </span> : null,
              ])}
            </li>
          ))
        }
      </ul>

      <div class="skills-avatar" aria-hidden="true"></div>
    </section>

    <!-- Experience -->
    <section class="resume-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="resume-section-title">Professional Experience</h2>

      {
        experience.map((role) => (
          <article
            class:list={[
              'mt-4 first:mt-3',
              role.company === 'Greenhouse Software' && 'greenhouse-stage',
            ]}
          >
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <h3 class="resume-role-header">
                {role.company === 'Greenhouse Software' ? (
                  <span class="greenhouse-trigger">{role.company}</span>
                ) : (
                  role.company
                )}{' '}
                <span class="font-normal text-slate-500">|</span>{' '}
                <span class="font-normal">{role.location}</span>
              </h3>
            </div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <p class="resume-role-title">
                {role.company === 'Otti, Inc.' ? (
                  <span class="role-cycle">
                    Founding{' '}
                    <span class="role-cycle-word">
                      <span class="role-cycle-original">Engineer</span>
                      <span class="role-cycle-overlay" aria-hidden="true" />
                    </span>
                  </span>
                ) : (
                  role.title
                )}
              </p>
              <p class="resume-meta">{role.start} – {role.end}</p>
            </div>
            {role.bullets.length > 0 && (
              <ul class="resume-bullets">
                {role.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
            {role.company === 'Greenhouse Software' && (
              <>
                <div class="greenhouse-supercomputer" aria-hidden="true">
                  {/* CRT screen overlay — covers the painted "g" while a
                      scorecard rating flashes through. SVG injected by JS
                      (runScorecardFlash in greenhouse-cascade.ts). */}
                  <div class="greenhouse-screen" aria-hidden="true"></div>
                </div>
                <div class="greenhouse-avatar" aria-hidden="true" />
              </>
            )}
          </article>
        ))
      }

      <article class="mt-4">
        <h3 class="resume-role-header">
          {education.school} <span class="font-normal text-slate-500">|</span>{' '}
          <span class="font-normal">{education.location}</span>
        </h3>
        <p class="resume-role-title">{education.degree}</p>
      </article>
    </section>

    <!-- View-source trigger — visible affordance and mobile equivalent of
         right-click. Styled like an old "view-source:" URL prefix so it reads
         as "click here for source" without being a CTA. -->
    <div class="resume-actions">
      <button type="button" class="resume-view-source" aria-label="View page source">
        view-source:tfrey7.com
      </button>
    </div>
  </main>
</Base>

<script>
  import { initAllEggs } from '../scripts/eggs/manifest';

  initAllEggs();
</script>
